PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/breach-radar
FRONTEND_URL=http://127.0.0.1:5174
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5174

JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Redis is optional for payment flow. Enable only when a Redis server is available.
REDIS_ENABLED=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT_MS=1500

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

SCAN_WORKER_CONCURRENCY=3

# Breach Radar monitoring
MONITORING_ENABLED=true
DAILY_SCAN_CRON=0 2 * * *
SSL_MONITORING_CRON=0 2 * * *
DOMAIN_EXPIRY_CRON=0 2 * * *
DAILY_SUMMARY_CRON=30 2 * * *

# Email alerts (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Breach Radar <alerts@example.com>"
